FROM pgvector/pgvector:pg18 AS builder

# Install Ruby + build deps; use postgresql-server-dev-18 so the pg gem
# compiles against the same PG18 headers that are in this image.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ruby ruby-dev build-essential postgresql-server-dev-18 && \
    gem install pg oj --no-document && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app
ENV PGDATA=/pgdata
# Trust auth — seed runs as root over TCP, not as the postgres OS user.
ENV DATABASE_URL=postgres://postgres@localhost/rinha

COPY resources/references.json.gz resources/
COPY scripts/seed.rb scripts/

RUN mkdir -p "$PGDATA" && chown postgres:postgres "$PGDATA"

RUN gosu postgres initdb -D "$PGDATA" -A trust && \
    gosu postgres pg_ctl -D "$PGDATA" \
      -o "-c listen_addresses=localhost -c maintenance_work_mem=8GB -c dynamic_shared_memory_type=mmap" \
      start -w && \
    gosu postgres createdb rinha && \
    ruby scripts/seed.rb && \
    gosu postgres psql -d rinha -c \
      "CREATE INDEX ON refs USING hnsw (embedding vector_l2_ops) WITH (m=16, ef_construction=64);" && \
    echo "shared_buffers = 64MB"         >> "$PGDATA/postgresql.conf" && \
    echo "work_mem = 4MB"                >> "$PGDATA/postgresql.conf" && \
    echo "maintenance_work_mem = 32MB"   >> "$PGDATA/postgresql.conf" && \
    echo "max_connections = 20"          >> "$PGDATA/postgresql.conf" && \
    echo "listen_addresses = '*'"        >> "$PGDATA/postgresql.conf" && \
    echo "host all all 0.0.0.0/0 trust" >> "$PGDATA/pg_hba.conf" && \
    gosu postgres pg_ctl -D "$PGDATA" stop -w


FROM pgvector/pgvector:pg18

# Override PG18's new default (/var/lib/postgresql/18/docker) so the
# entrypoint finds pre-baked data instead of initialising a fresh cluster.
ENV PGDATA=/var/lib/postgresql/data

COPY --chown=postgres:postgres --from=builder /pgdata /var/lib/postgresql/data
